# Floosball Backend - Environment Variables
# Copy to .env for local development, or set via `fly secrets set` for production

# Server
PORT=8000
TIMING_MODE=fast          # fast | turbo | slow | scheduled | catchup | demo
FRESH_START=false         # Set to true to clear DB on startup

# Database (default: ./data/)
# DATABASE_DIR=/data      # Set to Fly volume mount path in production

# Authentication (Clerk)
# CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# Admin
# ADMIN_PASSWORD=your-admin-password

# Email (Resend)
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM=Floosball <noreply@floosball.com>

# CORS (comma-separated additional origins beyond defaults)
# CORS_ORIGINS=https://your-preview-domain.vercel.app
