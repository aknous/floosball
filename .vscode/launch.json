{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Floosball Refactored (Fast)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/floosball.py",
            "console": "integratedTerminal",
            "args": ["--refactored", "--timing=fast"],
            "cwd": "${workspaceFolder}",
            "justMyCode": true
        },
        {
            "name": "Floosball Fresh Start (Fast)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/floosball.py",
            "console": "integratedTerminal",
            "args": ["--refactored", "--timing=fast", "--fresh"],
            "cwd": "${workspaceFolder}",
            "justMyCode": true
        },
        {
            "name": "Floosball API Server",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "floosball_api:app",
                "--host", "0.0.0.0",
                "--port", "8000",
                "--reload"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Floosball Legacy",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/floosball.py",
            "console": "integratedTerminal",
            "args": ["--timing=fast"],
            "cwd": "${workspaceFolder}",
            "justMyCode": true
        },
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}"
        },
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}